[{"id": 1, "category": "接续・逆接", "pattern": "〜にもかかわらず", "meaning": "尽管…却…", "example_jp": "雨にもかかわらず、試合は行われた。", "example_cn": "尽管下雨，比赛照常进行。"}, {"id": 2, "category": "接续・逆接", "pattern": "〜ものの", "meaning": "虽然…但是…", "example_jp": "免許は取ったものの、車がない。", "example_cn": "虽然拿到驾照了，但没车。"}, {"id": 3, "category": "接续・逆接", "pattern": "〜とはいえ", "meaning": "虽说…但…", "example_jp": "春とはいえ、まだ寒い。", "example_cn": "虽说是春天，但还很冷。"}, {"id": 4, "category": "接续・逆接", "pattern": "〜ながら（も）", "meaning": "尽管…还是…", "example_jp": "狭いながらも、楽しい我が家。", "example_cn": "虽然狭小，但其乐融融的家。"}, {"id": 5, "category": "接续・逆接", "pattern": "〜くせに", "meaning": "明明…却…（含贬义）", "example_jp": "知っているくせに、教えてくれない。", "example_cn": "明明知道却不告诉我。"}, {"id": 6, "category": "接续・逆接", "pattern": "〜わりに（は）", "meaning": "与…相比意外…", "example_jp": "値段のわりにおいしい。", "example_cn": "比起价格意外好吃。"}, {"id": 7, "category": "接续・逆接", "pattern": "〜どころか", "meaning": "别说…就连…", "example_jp": "漢字どころか、ひらがなも書けない。", "example_cn": "别说汉字，连平假名都不会。"}, {"id": 8, "category": "接续・逆接", "pattern": "〜つつ（も）", "meaning": "一边…一边…/虽然…", "example_jp": "悪いと知りつつ、嘘をついた。", "example_cn": "明知不好却撒了谎。"}, {"id": 9, "category": "接续・逆接", "pattern": "〜ところを", "meaning": "正…的时候/在…之际", "example_jp": "お忙しいところを恐縮です。", "example_cn": "百忙之中实在抱歉。"}, {"id": 10, "category": "接续・逆接", "pattern": "〜にしては", "meaning": "作为…来说意外…", "example_jp": "新人にしては仕事が早い。", "example_cn": "作为新人工作意外地快。"}, {"id": 11, "category": "接续・逆接", "pattern": "〜にしろ〜にしろ", "meaning": "无论…还是…", "example_jp": "行くにしろ行かないにしろ連絡して。", "example_cn": "去也好不去也好都联系一下。"}, {"id": 12, "category": "接续・逆接", "pattern": "〜にせよ〜にせよ", "meaning": "无论…还是…（书面）", "example_jp": "賛成にせよ反対にせよ理由を述べよ。", "example_cn": "无论赞成还是反对都要说明理由。"}, {"id": 13, "category": "接续・逆接", "pattern": "〜であれ〜であれ", "meaning": "无论…", "example_jp": "男であれ女であれ平等だ。", "example_cn": "无论男女都平等。"}, {"id": 14, "category": "接续・逆接", "pattern": "〜ようと〜まいと", "meaning": "无论是否…", "example_jp": "雨が降ろうと降るまいと行く。", "example_cn": "无论下不下雨都去。"}, {"id": 15, "category": "接续・逆接", "pattern": "〜にしたって", "meaning": "即使…也…（口语）", "example_jp": "子供にしたって理解できる。", "example_cn": "即使是孩子也能理解。"}, {"id": 16, "category": "接续・逆接", "pattern": "〜とはいうものの", "meaning": "话虽如此…", "example_jp": "便利とはいうものの問題もある。", "example_cn": "话说方便，但也有问题。"}, {"id": 17, "category": "接续・逆接", "pattern": "〜ばかりに", "meaning": "就因为…", "example_jp": "急いだばかりに失敗した。", "example_cn": "就因为太急失败了。"}, {"id": 18, "category": "接续・逆接", "pattern": "〜あまり（に）", "meaning": "由于过度…", "example_jp": "緊張のあまり声が出ない。", "example_cn": "因过度紧张说不出话。"}, {"id": 19, "category": "接续・逆接", "pattern": "〜ゆえ（に）", "meaning": "因为…（书面）", "example_jp": "若さゆえの過ちだ。", "example_cn": "因年轻所犯的错。"}, {"id": 20, "category": "接续・逆接", "pattern": "〜からこそ", "meaning": "正因为…才…", "example_jp": "君だからこそ頼む。", "example_cn": "正因为是你才拜托。"}, {"id": 21, "category": "接续・逆接", "pattern": "〜ことだから", "meaning": "因为是…所以…", "example_jp": "彼のことだから時間通り来る。", "example_cn": "因为是他所以会准时来。"}, {"id": 22, "category": "接续・逆接", "pattern": "〜だけに", "meaning": "正因为…所以…", "example_jp": "経験者だけに頼りになる。", "example_cn": "正因为有经验所以可靠。"}, {"id": 23, "category": "接续・逆接", "pattern": "〜だけあって", "meaning": "不愧是…", "example_jp": "プロだけあってうまい。", "example_cn": "不愧是专业的，真厉害。"}, {"id": 24, "category": "接续・逆接", "pattern": "〜ばかりか", "meaning": "不仅…而且…", "example_jp": "彼は英語ばかりか中国語も話せる。", "example_cn": "他不仅英语，连中文也会说。"}, {"id": 25, "category": "接续・逆接", "pattern": "〜のみならず", "meaning": "不仅…而且…（书面）", "example_jp": "国内のみならず海外でも有名だ。", "example_cn": "不仅国内，海外也有名。"}, {"id": 26, "category": "程度・比较", "pattern": "〜ほど〜はない", "meaning": "没有比…更…的", "example_jp": "健康ほど大切なものはない。", "example_cn": "没有比健康更重要的东西。"}, {"id": 27, "category": "程度・比较", "pattern": "〜ば〜ほど", "meaning": "越…越…", "example_jp": "話せば話すほど親しくなる。", "example_cn": "越说越亲近。"}, {"id": 28, "category": "程度・比较", "pattern": "〜くらい/ぐらい", "meaning": "…程度", "example_jp": "泣きたいくらい嬉しい。", "example_cn": "高兴得想哭。"}, {"id": 29, "category": "程度・比较", "pattern": "〜やら〜やら", "meaning": "又…又…", "example_jp": "嬉しいやら恥ずかしいやら。", "example_cn": "又开心又害羞。"}, {"id": 30, "category": "程度・比较", "pattern": "〜といい〜といい", "meaning": "无论是…还是…都…", "example_jp": "色といいデザインといい最高だ。", "example_cn": "颜色也好设计也好都最棒。"}, {"id": 31, "category": "程度・比较", "pattern": "〜にもまして", "meaning": "比…更甚", "example_jp": "去年にもまして暑い。", "example_cn": "比去年还热。"}, {"id": 32, "category": "程度・比较", "pattern": "〜に限る", "meaning": "最好是…", "example_jp": "夏はビールに限る。", "example_cn": "夏天就得喝啤酒。"}, {"id": 33, "category": "程度・比较", "pattern": "〜に越したことはない", "meaning": "最好…", "example_jp": "用心に越したことはない。", "example_cn": "小心为上。"}, {"id": 34, "category": "程度・比较", "pattern": "〜どころではない", "meaning": "哪里谈得上…", "example_jp": "勉強どころではない。", "example_cn": "哪里还顾得上学习。"}, {"id": 35, "category": "程度・比较", "pattern": "〜に比べて", "meaning": "与…相比", "example_jp": "去年に比べて売上が増えた。", "example_cn": "与去年相比销量增加了。"}, {"id": 36, "category": "程度・比较", "pattern": "〜に対して", "meaning": "对于…", "example_jp": "客に対して丁寧に話す。", "example_cn": "对客人要礼貌讲话。"}, {"id": 37, "category": "程度・比较", "pattern": "〜に反して", "meaning": "与…相反", "example_jp": "予想に反して負けた。", "example_cn": "出乎预料地输了。"}, {"id": 38, "category": "程度・比较", "pattern": "〜とともに", "meaning": "随着…/和…一起", "example_jp": "時代とともに変化する。", "example_cn": "随时代而变化。"}, {"id": 39, "category": "程度・比较", "pattern": "〜につれて", "meaning": "随着…", "example_jp": "年をとるにつれて忘れっぽくなる。", "example_cn": "随着年龄增长越来越健忘。"}, {"id": 40, "category": "程度・比较", "pattern": "〜にしたがって", "meaning": "随着…/按照…", "example_jp": "ルールにしたがって行動する。", "example_cn": "按规则行动。"}, {"id": 41, "category": "程度・比较", "pattern": "〜とともに〜も", "meaning": "既…又…", "example_jp": "便利とともに危険も増えた。", "example_cn": "方便的同时危险也增加。"}, {"id": 42, "category": "程度・比较", "pattern": "〜にひきかえ", "meaning": "与…相反", "example_jp": "兄にひきかえ弟は静かだ。", "example_cn": "与哥哥相反弟弟很安静。"}, {"id": 43, "category": "程度・比较", "pattern": "〜に至って", "meaning": "到了…才…", "example_jp": "病気に至って後悔した。", "example_cn": "到生病了才后悔。"}, {"id": 44, "category": "程度・比较", "pattern": "〜に至っては", "meaning": "至于…", "example_jp": "兄に至っては全く勉強しない。", "example_cn": "至于哥哥完全不学习。"}, {"id": 45, "category": "程度・比较", "pattern": "〜のなんのって", "meaning": "非常…（口语）", "example_jp": "暑いのなんのって。", "example_cn": "热得不得了。"}, {"id": 46, "category": "程度・比较", "pattern": "〜と言ったらない", "meaning": "…得不得了", "example_jp": "嬉しいと言ったらない。", "example_cn": "高兴得不得了。"}, {"id": 47, "category": "程度・比较", "pattern": "〜極まりない", "meaning": "极其…", "example_jp": "失礼極まりない態度。", "example_cn": "极其失礼的态度。"}, {"id": 48, "category": "程度・比较", "pattern": "〜の至り", "meaning": "…之至", "example_jp": "光栄の至りです。", "example_cn": "荣幸之至。"}, {"id": 49, "category": "程度・比较", "pattern": "〜の極み", "meaning": "…的极点", "example_jp": "贅沢の極み。", "example_cn": "奢侈的极点。"}, {"id": 50, "category": "程度・比较", "pattern": "〜たる", "meaning": "作为…", "example_jp": "教師たる者は模範であれ。", "example_cn": "作为教师应当成为模范。"}, {"id": 51, "category": "时间・契机", "pattern": "〜たとたん（に）", "meaning": "刚一…就…", "example_jp": "ドアを開けたとたん犬が飛び出した。", "example_cn": "一开门狗就冲出来了。"}, {"id": 52, "category": "时间・契机", "pattern": "〜が早いか", "meaning": "刚一…就…", "example_jp": "席に着くが早いか食べ始めた。", "example_cn": "一坐下就开始吃了。"}, {"id": 53, "category": "时间・契机", "pattern": "〜や否や", "meaning": "刚一…就…（书面）", "example_jp": "発表や否や売り切れた。", "example_cn": "一发表就卖光了。"}, {"id": 54, "category": "时间・契机", "pattern": "〜なり", "meaning": "刚一…就…", "example_jp": "帰るなり寝てしまった。", "example_cn": "一回来就睡了。"}, {"id": 55, "category": "时间・契机", "pattern": "〜次第", "meaning": "一…就…", "example_jp": "決まり次第連絡します。", "example_cn": "一定下来就联系。"}, {"id": 56, "category": "时间・契机", "pattern": "〜うちに", "meaning": "趁着…/在…期间", "example_jp": "若いうちに勉強しなさい。", "example_cn": "趁年轻好好学。"}, {"id": 57, "category": "时间・契机", "pattern": "〜ないうちに", "meaning": "趁还没…", "example_jp": "暗くならないうちに帰ろう。", "example_cn": "趁天还没黑回去吧。"}, {"id": 58, "category": "时间・契机", "pattern": "〜際（に）", "meaning": "…的时候", "example_jp": "出発する際に確認する。", "example_cn": "出发时确认一下。"}, {"id": 59, "category": "时间・契机", "pattern": "〜にあたって", "meaning": "在…之际", "example_jp": "卒業にあたってお礼を言う。", "example_cn": "在毕业之际致谢。"}, {"id": 60, "category": "时间・契机", "pattern": "〜に先立って", "meaning": "在…之前", "example_jp": "会議に先立って資料を配る。", "example_cn": "会议前发资料。"}, {"id": 61, "category": "时间・契机", "pattern": "〜を機に", "meaning": "以…为契机", "example_jp": "結婚を機に転職した。", "example_cn": "以结婚为契机换了工作。"}, {"id": 62, "category": "时间・契机", "pattern": "〜を契機に", "meaning": "以…为契机", "example_jp": "事件を契機に法律が変わった。", "example_cn": "以事件为契机法律改变了。"}, {"id": 63, "category": "时间・契机", "pattern": "〜を皮切りに", "meaning": "以…为开端", "example_jp": "東京を皮切りに全国を回る。", "example_cn": "以东京为开端巡回全国。"}, {"id": 64, "category": "时间・契机", "pattern": "〜てからでないと", "meaning": "不…就不行", "example_jp": "登録してからでないと使えない。", "example_cn": "不注册就不能用。"}, {"id": 65, "category": "时间・契机", "pattern": "〜てはじめて", "meaning": "…之后才…", "example_jp": "失ってはじめて大切さがわかる。", "example_cn": "失去后才知珍贵。"}, {"id": 66, "category": "时间・契机", "pattern": "〜つつある", "meaning": "正在…中", "example_jp": "経済は回復しつつある。", "example_cn": "经济正在恢复中。"}, {"id": 67, "category": "时间・契机", "pattern": "〜最中（に）", "meaning": "正在…的时候", "example_jp": "食事の最中に電話が鳴った。", "example_cn": "正在吃饭时电话响了。"}, {"id": 68, "category": "时间・契机", "pattern": "〜かと思うと", "meaning": "刚…就…", "example_jp": "晴れたかと思うとまた雨だ。", "example_cn": "刚晴又下雨了。"}, {"id": 69, "category": "时间・契机", "pattern": "〜か〜ないかのうちに", "meaning": "刚…还没…就…", "example_jp": "言うか言わないかのうちに走り出した。", "example_cn": "话还没说完就跑了。"}, {"id": 70, "category": "时间・契机", "pattern": "〜て以来", "meaning": "自从…以来", "example_jp": "彼に会って以来連絡がない。", "example_cn": "自从见过他以后没联系。"}, {"id": 71, "category": "时间・契机", "pattern": "〜ところに/ところへ", "meaning": "正在…时候", "example_jp": "出かけるところに電話が来た。", "example_cn": "正要出门时来电话了。"}, {"id": 72, "category": "时间・契机", "pattern": "〜ところで", "meaning": "即使…也…", "example_jp": "今さら謝ったところで遅い。", "example_cn": "现在道歉也晚了。"}, {"id": 73, "category": "时间・契机", "pattern": "〜ばそれまでだ", "meaning": "如果…就完了", "example_jp": "壊れればそれまでだ。", "example_cn": "坏了就完了。"}, {"id": 74, "category": "时间・契机", "pattern": "〜きり", "meaning": "…之后再没…", "example_jp": "出かけたきり戻らない。", "example_cn": "出去后再没回来。"}, {"id": 75, "category": "时间・契机", "pattern": "〜まま", "meaning": "保持…状态", "example_jp": "靴を履いたまま入る。", "example_cn": "穿着鞋进入。"}, {"id": 76, "category": "目的・原因・结果", "pattern": "〜ように", "meaning": "为了…", "example_jp": "聞こえるように大きな声で。", "example_cn": "大声以便听到。"}, {"id": 77, "category": "目的・原因・结果", "pattern": "〜ため（に）", "meaning": "为了…/因为…", "example_jp": "健康のために運動する。", "example_cn": "为了健康运动。"}, {"id": 78, "category": "目的・原因・结果", "pattern": "〜べく", "meaning": "为了…（书面）", "example_jp": "目標を達成すべく努力する。", "example_cn": "为达成目标而努力。"}, {"id": 79, "category": "目的・原因・结果", "pattern": "〜ように", "meaning": "希望…", "example_jp": "成功しますように。", "example_cn": "祝你成功。"}, {"id": 80, "category": "目的・原因・结果", "pattern": "〜ことなく", "meaning": "没有…就…", "example_jp": "休むことなく働く。", "example_cn": "不停地工作。"}, {"id": 81, "category": "目的・原因・结果", "pattern": "〜ずに", "meaning": "没…就…", "example_jp": "朝食を食べずに出かけた。", "example_cn": "没吃早餐就出门。"}, {"id": 82, "category": "目的・原因・结果", "pattern": "〜ないで", "meaning": "不…而…", "example_jp": "傘を持たないで出た。", "example_cn": "没带伞就出去了。"}, {"id": 83, "category": "目的・原因・结果", "pattern": "〜せいで", "meaning": "由于…（消极）", "example_jp": "雨のせいで遅刻した。", "example_cn": "因为下雨迟到了。"}, {"id": 84, "category": "目的・原因・结果", "pattern": "〜おかげで", "meaning": "多亏…", "example_jp": "先生のおかげで合格した。", "example_cn": "多亏老师合格了。"}, {"id": 85, "category": "目的・原因・结果", "pattern": "〜あげく", "meaning": "结果…（消极）", "example_jp": "悩んだあげく辞めた。", "example_cn": "烦恼之后辞职了。"}, {"id": 86, "category": "目的・原因・结果", "pattern": "〜末（に）", "meaning": "经过…最后…", "example_jp": "考えた末に決めた。", "example_cn": "考虑后决定了。"}, {"id": 87, "category": "目的・原因・结果", "pattern": "〜結果", "meaning": "…的结果", "example_jp": "努力の結果合格した。", "example_cn": "努力的结果是合格了。"}, {"id": 88, "category": "目的・原因・结果", "pattern": "〜につき", "meaning": "因为…（书面）", "example_jp": "工事中につき通行止め。", "example_cn": "因施工禁止通行。"}, {"id": 89, "category": "目的・原因・结果", "pattern": "〜ことから", "meaning": "因为…", "example_jp": "似ていることから誤解された。", "example_cn": "因为相似被误会。"}, {"id": 90, "category": "目的・原因・结果", "pattern": "〜ことだし", "meaning": "因为…（轻微原因）", "example_jp": "雨も降ることだし帰ろう。", "example_cn": "也下雨了回去吧。"}, {"id": 91, "category": "目的・原因・结果", "pattern": "〜以上（は）", "meaning": "既然…", "example_jp": "約束した以上守るべきだ。", "example_cn": "既然约定就该遵守。"}, {"id": 92, "category": "目的・原因・结果", "pattern": "〜上は", "meaning": "既然…（书面）", "example_jp": "やる上は最後まで。", "example_cn": "既然做就到最后。"}, {"id": 93, "category": "目的・原因・结果", "pattern": "〜からには", "meaning": "既然…", "example_jp": "やるからには本気で。", "example_cn": "既然做就认真。"}, {"id": 94, "category": "目的・原因・结果", "pattern": "〜ものだから", "meaning": "因为…（辩解）", "example_jp": "急いだものだから忘れた。", "example_cn": "因为太急忘了。"}, {"id": 95, "category": "目的・原因・结果", "pattern": "〜もので", "meaning": "因为…（辩解）", "example_jp": "初めてのもので緊張した。", "example_cn": "因为是第一次紧张了。"}, {"id": 96, "category": "目的・原因・结果", "pattern": "〜ばかりに", "meaning": "就因为…（消极）", "example_jp": "信じたばかりに損をした。", "example_cn": "就因相信而吃亏。"}, {"id": 97, "category": "目的・原因・结果", "pattern": "〜だけに", "meaning": "正因为…反而…", "example_jp": "期待していただけに残念だ。", "example_cn": "正因为期待所以遗憾。"}, {"id": 98, "category": "目的・原因・结果", "pattern": "〜とあって", "meaning": "因为…（特殊场合）", "example_jp": "祭りとあって人が多い。", "example_cn": "因为是节日人很多。"}, {"id": 99, "category": "目的・原因・结果", "pattern": "〜ことに（は）", "meaning": "令人…的是", "example_jp": "驚いたことに優勝した。", "example_cn": "令人惊讶的是获得了冠军。"}, {"id": 100, "category": "目的・原因・结果", "pattern": "〜まいか", "meaning": "是不是…/不会…吧", "example_jp": "失敗するまいかと心配だ。", "example_cn": "担心会不会失败。"}, {"id": 101, "category": "推量・判断", "pattern": "〜に違いない", "meaning": "一定是…", "example_jp": "彼が犯人に違いない。", "example_cn": "他一定是犯人。"}, {"id": 102, "category": "推量・判断", "pattern": "〜に決まっている", "meaning": "肯定是…", "example_jp": "嘘に決まっている。", "example_cn": "肯定是谎言。"}, {"id": 103, "category": "推量・判断", "pattern": "〜恐れがある", "meaning": "有…的危险", "example_jp": "雨の恐れがある。", "example_cn": "有下雨的可能。"}, {"id": 104, "category": "推量・判断", "pattern": "〜かねない", "meaning": "可能会…（消极）", "example_jp": "事故になりかねない。", "example_cn": "可能会出事故。"}, {"id": 105, "category": "推量・判断", "pattern": "〜かねる", "meaning": "难以…", "example_jp": "賛成しかねる。", "example_cn": "难以赞成。"}, {"id": 106, "category": "推量・判断", "pattern": "〜ようがない", "meaning": "无法…", "example_jp": "連絡しようがない。", "example_cn": "没办法联系。"}, {"id": 107, "category": "推量・判断", "pattern": "〜得る/得ない", "meaning": "可能/不可能", "example_jp": "あり得ない話だ。", "example_cn": "不可能的事。"}, {"id": 108, "category": "推量・判断", "pattern": "〜まい", "meaning": "不会…吧", "example_jp": "二度と行くまい。", "example_cn": "再不去了。"}, {"id": 109, "category": "推量・判断", "pattern": "〜っこない", "meaning": "绝不可能…（口语）", "example_jp": "勝てっこない。", "example_cn": "绝赢不了。"}, {"id": 110, "category": "推量・判断", "pattern": "〜わけがない", "meaning": "不可能…", "example_jp": "知っているわけがない。", "example_cn": "不可能知道。"}, {"id": 111, "category": "推量・判断", "pattern": "〜わけではない", "meaning": "并非…", "example_jp": "嫌いなわけではない。", "example_cn": "并非讨厌。"}, {"id": 112, "category": "推量・判断", "pattern": "〜わけにはいかない", "meaning": "不能…", "example_jp": "諦めるわけにはいかない。", "example_cn": "不能放弃。"}, {"id": 113, "category": "推量・判断", "pattern": "〜ないわけにはいかない", "meaning": "不能不…", "example_jp": "行かないわけにはいかない。", "example_cn": "不能不去。"}, {"id": 114, "category": "推量・判断", "pattern": "〜はずがない", "meaning": "不可能…", "example_jp": "そんなはずがない。", "example_cn": "不可能那样。"}, {"id": 115, "category": "推量・判断", "pattern": "〜とは限らない", "meaning": "未必…", "example_jp": "高いものがいいとは限らない。", "example_cn": "贵的未必好。"}, {"id": 116, "category": "推量・判断", "pattern": "〜ないとも限らない", "meaning": "未必不…", "example_jp": "雨が降らないとも限らない。", "example_cn": "未必不下雨。"}, {"id": 117, "category": "推量・判断", "pattern": "〜ではあるまいか", "meaning": "莫非…吧（书面）", "example_jp": "本当ではあるまいか。", "example_cn": "莫非是真的吧。"}, {"id": 118, "category": "推量・判断", "pattern": "〜とみえる", "meaning": "看来…", "example_jp": "疲れたとみえる。", "example_cn": "看来累了。"}, {"id": 119, "category": "推量・判断", "pattern": "〜ものと思われる", "meaning": "认为…", "example_jp": "正しいものと思われる。", "example_cn": "认为是正确的。"}, {"id": 120, "category": "推量・判断", "pattern": "〜ようだ/みたいだ", "meaning": "好像…", "example_jp": "風邪のようだ。", "example_cn": "好像感冒了。"}, {"id": 121, "category": "推量・判断", "pattern": "〜らしい", "meaning": "好像…/像…样的", "example_jp": "彼らしい行動だ。", "example_cn": "像他风格的行动。"}, {"id": 122, "category": "推量・判断", "pattern": "〜そうだ", "meaning": "听说…/看起来…", "example_jp": "雨が降りそうだ。", "example_cn": "看起来要下雨。"}, {"id": 123, "category": "推量・判断", "pattern": "〜とか", "meaning": "据说…", "example_jp": "明日来るとか。", "example_cn": "据说明天来。"}, {"id": 124, "category": "推量・判断", "pattern": "〜ということだ", "meaning": "据说…", "example_jp": "中止になったということだ。", "example_cn": "据说中止了。"}, {"id": 125, "category": "推量・判断", "pattern": "〜ものがある", "meaning": "确实有…的一面", "example_jp": "感動的なものがある。", "example_cn": "确实令人感动。"}, {"id": 126, "category": "评价・主张", "pattern": "〜べきだ", "meaning": "应该…", "example_jp": "正直に言うべきだ。", "example_cn": "应该诚实地说。"}, {"id": 127, "category": "评价・主张", "pattern": "〜べきではない", "meaning": "不应该…", "example_jp": "嘘をつくべきではない。", "example_cn": "不应该撒谎。"}, {"id": 128, "category": "评价・主张", "pattern": "〜ものだ", "meaning": "理应…/常常…", "example_jp": "親は子を思うものだ。", "example_cn": "父母总是想着孩子。"}, {"id": 129, "category": "评价・主张", "pattern": "〜ものではない", "meaning": "不该…", "example_jp": "そんなことを言うものではない。", "example_cn": "不该说那种话。"}, {"id": 130, "category": "评价・主张", "pattern": "〜ことだ", "meaning": "应当…（建议）", "example_jp": "早く寝ることだ。", "example_cn": "应该早点睡。"}, {"id": 131, "category": "评价・主张", "pattern": "〜ことはない", "meaning": "没必要…", "example_jp": "心配することはない。", "example_cn": "没必要担心。"}, {"id": 132, "category": "评价・主张", "pattern": "〜までもない", "meaning": "用不着…", "example_jp": "言うまでもない。", "example_cn": "不用说。"}, {"id": 133, "category": "评价・主张", "pattern": "〜にすぎない", "meaning": "只不过…", "example_jp": "冗談にすぎない。", "example_cn": "只是开玩笑。"}, {"id": 134, "category": "评价・主张", "pattern": "〜にほかならない", "meaning": "正是…", "example_jp": "努力の結果にほかならない。", "example_cn": "正是努力的结果。"}, {"id": 135, "category": "评价・主张", "pattern": "〜にあたらない", "meaning": "用不着…", "example_jp": "驚くにあたらない。", "example_cn": "用不着惊讶。"}, {"id": 136, "category": "评价・主张", "pattern": "〜に足る", "meaning": "值得…", "example_jp": "尊敬に足る人物。", "example_cn": "值得尊敬的人物。"}, {"id": 137, "category": "评价・主张", "pattern": "〜に値する", "meaning": "值得…", "example_jp": "称賛に値する。", "example_cn": "值得称赞。"}, {"id": 138, "category": "评价・主张", "pattern": "〜てたまらない", "meaning": "…得不得了", "example_jp": "眠くてたまらない。", "example_cn": "困得不得了。"}, {"id": 139, "category": "评价・主张", "pattern": "〜てならない", "meaning": "…得不得了", "example_jp": "残念でならない。", "example_cn": "遗憾得不得了。"}, {"id": 140, "category": "评价・主张", "pattern": "〜てしようがない", "meaning": "…得不行", "example_jp": "気になってしようがない。", "example_cn": "在意得不行。"}, {"id": 141, "category": "评价・主张", "pattern": "〜ずにはいられない", "meaning": "不禁…", "example_jp": "笑わずにはいられない。", "example_cn": "不禁要笑。"}, {"id": 142, "category": "评价・主张", "pattern": "〜ないではいられない", "meaning": "不禁…", "example_jp": "泣かないではいられない。", "example_cn": "禁不住要哭。"}, {"id": 143, "category": "评价・主张", "pattern": "〜ざるを得ない", "meaning": "不得不…", "example_jp": "認めざるを得ない。", "example_cn": "不得不承认。"}, {"id": 144, "category": "评价・主张", "pattern": "〜より（ほか）ない", "meaning": "只能…", "example_jp": "待つよりない。", "example_cn": "只能等待。"}, {"id": 145, "category": "评价・主张", "pattern": "〜しかない", "meaning": "只能…", "example_jp": "諦めるしかない。", "example_cn": "只能放弃。"}, {"id": 146, "category": "评价・主张", "pattern": "〜ことか", "meaning": "多么…啊", "example_jp": "どんなに嬉しいことか。", "example_cn": "多么开心啊。"}, {"id": 147, "category": "评价・主张", "pattern": "〜ものか", "meaning": "怎么会…呢", "example_jp": "そんなことあるものか。", "example_cn": "怎么会有那种事。"}, {"id": 148, "category": "评价・主张", "pattern": "〜とは", "meaning": "竟然…", "example_jp": "彼が来ないとは。", "example_cn": "他竟然不来。"}, {"id": 149, "category": "评价・主张", "pattern": "〜なんて", "meaning": "竟然…", "example_jp": "失敗するなんて。", "example_cn": "竟然失败了。"}, {"id": 150, "category": "评价・主张", "pattern": "〜ものなら", "meaning": "如果能…（多难以实现）", "example_jp": "できるものならやってみろ。", "example_cn": "能做就做做看。"}]